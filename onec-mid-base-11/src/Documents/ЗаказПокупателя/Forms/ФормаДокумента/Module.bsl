#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура РассчитатьСуммуСтроки(ТекущиеДанные)
	
	// >>> Варганов Д В Расчет суммы строки с учетом значения Согласованная скидка 07.05.2026
	// Сумма строки будет расчитана с учетом скидки + Согласованная скидка и контроля бщей скидки больше 100%
	// Исходный код:
	//КоэффициентСкидки = 1 - ТекущиеДанные.Скидка / 100;
	//ТекущиеДанные.Сумма = ТекущиеДанные.Цена * ТекущиеДанные.Количество * КоэффициентСкидки;
	// Новый код:
	КоэффициентСкидки = 1 - (ТекущиеДанные.Скидка + Объект.ДЗ_СогласованнаяСкидка) / 100;
	Если КоэффициентСкидки <= 0 Тогда 
		ТекущиеДанные.Скидка = 0;
		ТекущиеДанные.Сумма = 0;
		Возврат;
	КонецЕсли;	
	ТекущиеДанные.Сумма = ТекущиеДанные.Цена * ТекущиеДанные.Количество * КоэффициентСкидки
	
КонецПроцедуры

&НаКлиенте
Процедура ДЗ_ПересчитатьТаблицу(Команда)
	
	// >>> Варганов Д В Обработчик команды ДЗ_ПересчитатьТаблицу 07.05.2026
	ПересчитатьТаблицуСоСкидкой();
	// <<< Варганов Д В Обработчик команды ДЗ_ПересчитатьТаблицу 07.05.2026
	
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьТаблицуСоСкидкой() 
	
	// >>> Варганов Д В Алгоритм управления пересчета обеих таблиц формы 07.05.2026
	// Пересчет таблицы товаров:
	Для Каждого Строка Из Объект.Товары Цикл 
		РассчитатьСуммуСтроки(Строка);
	КонецЦикла;
	// Пересчет таблицы услуг:
	Для Каждого Строка Из Объект.Услуги Цикл 
		РассчитатьСуммуСтроки(Строка);
	КонецЦикла;
	// Пересчет суммы документа:
	РассчитатьСуммуДокумента();
	// <<< Варганов Д В Алгоритм управления пересчета обеих таблиц формы 07.05.2026
	
КонецПроцедуры

&НаКлиенте
Асинх Процедура ДЗ_СогласованнаяСкидкаПриИзменении(Элемент)
	
	// >>> Варганов Д В Алгоритм выбора необходимости пересчета 07.05.2026
	Если ЗначениеЗаполнено(Объект.Товары) Или ЗначениеЗаполнено(Объект.Услуги) Тогда                 
		
		Вопрос = ВопросАсинх("Изменен процент скидки.Пересчитать таблицу товаров и услуг?",РежимДиалогаВопрос.ДаНет);
		ОтветНаВопрос = Ждать Вопрос;
		
		Если ОтветНаВопрос = КодВозвратаДиалога.Да Тогда           
			ПересчитатьТаблицуСоСкидкой();
		КонецЕсли;
	
	КонецЕсли;
	// <<< Варганов Д В Алгоритм выбора необходимости пересчета 07.05.2026
	
	
КонецПроцедуры


&НаКлиенте
Процедура РассчитатьСуммуДокумента()
	
	Объект.СуммаДокумента = Объект.Товары.Итог("Сумма") + Объект.Услуги.Итог("Сумма");
	
КонецПроцедуры

